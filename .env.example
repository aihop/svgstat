
# Server
HTTP_ADDR=:8080
HTTP_READ_TIMEOUT=30s
HTTP_WRITE_TIMEOUT=30s
HTTP_IDLE_TIMEOUT=60s

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_USER=svgstat
PG_PASSWORD=svgstat
PG_DATABASE=svgstat
PG_SSL_MODE=disable
PG_POOL_MAX=20
PG_POOL_MIN=5

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_POOL_SIZE=20
REDIS_MIN_IDLE_CONNS=5

# Logging
LOG_LEVEL=info

# Cache
CACHE_TTL=5m
